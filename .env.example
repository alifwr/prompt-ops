# ------------------------------------------------------------------------------
# PromptOps Deployment Environment Configurations
# Copy this file to '.env' and fill in your values.
# ------------------------------------------------------------------------------

# Gemini API Key for AI Agent reasoning loop (required)
GEMINI_API_KEY=your_gemini_api_key_here

# The IP Address or Domain of the host server where PromptOps is deployed.
# This MUST be reachable by the user's browser (do not use "localhost" if deploying to a remote host).
PUBLIC_GATEWAY_URL=http://localhost:3001
PUBLIC_WS_URL=ws://localhost:3001
